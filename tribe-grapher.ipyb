    {
      "cell_type": "code",
      "source": [
        "# Cell 6: Audio + Response Analytics (safe, offline, low-RAM, relative-to-silence)\n",
        "\n",
        "!pip -q install soundfile scipy imageio\n",
        "\n",
        "from pathlib import Path\n",
        "import gc\n",
        "import subprocess\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import soundfile as sf\n",
        "from scipy import signal\n",
        "\n",
        "FIG_DIR = Path(\"./cache/figures\")\n",
        "FIG_DIR.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "plt.rcParams.update({\n",
        "    \"figure.dpi\": 140,\n",
        "    \"savefig.dpi\": 180,\n",
        "    \"font.size\": 12,\n",
        "    \"axes.titlesize\": 14,\n",
        "    \"axes.labelsize\": 12,\n",
        "})\n",
        "\n",
        "MAX_SECONDS = 15\n",
        "SMOOTH_WINDOW = 3\n",
        "\n",
        "def _savefig(fig, name: str):\n",
        "    out = FIG_DIR / name\n",
        "    fig.savefig(out, bbox_inches=\"tight\")\n",
        "    print(\"saved:\", out)\n",
        "\n",
        "def _ensure_wav(path: Path) -> Path:\n",
        "    path = Path(path)\n",
        "    if path.suffix.lower() in {\".wav\", \".flac\", \".ogg\"}:\n",
        "        return path\n",
        "    wav_path = Path(\"./cache\") / f\"{path.stem}_converted.wav\"\n",
        "    subprocess.run(\n",
        "        [\"ffmpeg\", \"-y\", \"-i\", str(path), str(wav_path)],\n",
        "        check=True,\n",
        "        stdout=subprocess.DEVNULL,\n",
        "        stderr=subprocess.DEVNULL,\n",
        "    )\n",
        "    return wav_path\n",
        "\n",
        "def _load_audio_mono(path: Path):\n",
        "    y, sr = sf.read(str(path), always_2d=False)\n",
        "    if y.ndim > 1:\n",
        "        y = y.mean(axis=1)\n",
        "    return y.astype(np.float32), int(sr)\n",
        "\n",
        "def _trim_audio(y, sr, max_seconds):\n",
        "    max_len = min(len(y), int(sr * max_seconds))\n",
        "    return y[:max_len]\n",
        "\n",
        "def _plot_waveform(y, sr, title, fname):\n",
        "    step = max(1, len(y) // 150_000)\n",
        "    y_plot = y[::step]\n",
        "    t = (np.arange(len(y_plot)) * step) / sr\n",
        "\n",
        "    fig = plt.figure(figsize=(10, 2.8))\n",
        "    plt.plot(t, y_plot, lw=0.8, color=\"#111827\")\n",
        "    plt.title(title)\n",
        "    plt.xlabel(\"Time (s)\")\n",
        "    plt.ylabel(\"Amplitude\")\n",
        "    plt.grid(True, alpha=0.2)\n",
        "    _savefig(fig, fname)\n",
        "    plt.show()\n",
        "    plt.close(fig)\n",
        "\n",
        "def _plot_spectrogram(y, sr, title, fname):\n",
        "    f, t, Sxx = signal.spectrogram(\n",
        "        y,\n",
        "        fs=sr,\n",
        "        window=\"hann\",\n",
        "        nperseg=512,\n",
        "        noverlap=384,\n",
        "        scaling=\"spectrum\",\n",
        "        mode=\"magnitude\",\n",
        "    )\n",
        "    Sxx = np.maximum(Sxx, 1e-10)\n",
        "    S_db = 20 * np.log10(Sxx / np.max(Sxx))\n",
        "\n",
        "    fig = plt.figure(figsize=(10, 3.2))\n",
        "    plt.pcolormesh(t, f, S_db, shading=\"gouraud\", cmap=\"magma\")\n",
        "    plt.ylim(0, min(8000, sr // 2))\n",
        "    plt.colorbar(label=\"dB (relative)\")\n",
        "    plt.title(title)\n",
        "    plt.xlabel(\"Time (s)\")\n",
        "    plt.ylabel(\"Frequency (Hz)\")\n",
        "    plt.tight_layout()\n",
        "    _savefig(fig, fname)\n",
        "    plt.show()\n",
        "    plt.close(fig)\n",
        "\n",
        "def _plot_rms(y, sr, title, fname):\n",
        "    frame = 2048\n",
        "    hop = 512\n",
        "    count = max(1, (len(y) - frame) // hop + 1)\n",
        "    rms = np.empty(count, dtype=np.float32)\n",
        "\n",
        "    for i in range(count):\n",
        "        seg = y[i * hop : i * hop + frame]\n",
        "        rms[i] = np.sqrt(np.mean(seg * seg) + 1e-12)\n",
        "\n",
        "    times = (np.arange(count) * hop) / sr\n",
        "\n",
        "    fig = plt.figure(figsize=(10, 2.8))\n",
        "    plt.plot(times, rms, lw=1.2, color=\"#2563EB\")\n",
        "    plt.title(title)\n",
        "    plt.xlabel(\"Time (s)\")\n",
        "    plt.ylabel(\"RMS\")\n",
        "    plt.grid(True, alpha=0.2)\n",
        "    _savefig(fig, fname)\n",
        "    plt.show()\n",
        "    plt.close(fig)\n",
        "\n",
        "def _safe_audio_df(model, audio_path: Path):\n",
        "    try:\n",
        "        from tribev2.demo_utils import get_audio_and_text_events\n",
        "        events = pd.DataFrame([{\n",
        "            \"type\": \"Audio\",\n",
        "            \"filepath\": str(audio_path),\n",
        "            \"start\": 0,\n",
        "            \"timeline\": \"default\",\n",
        "            \"subject\": \"default\",\n",
        "        }])\n",
        "        df = get_audio_and_text_events(events, audio_only=True)\n",
        "        if \"type\" in df.columns:\n",
        "            df = df[df[\"type\"] == \"Audio\"].copy()\n",
        "        return df\n",
        "    except Exception:\n",
        "        df = model.get_events_dataframe(audio_path=audio_path)\n",
        "        if \"type\" in df.columns:\n",
        "            df = df[df[\"type\"] == \"Audio\"].copy()\n",
        "        return df\n",
        "\n",
        "def _reaction_from_preds(preds: np.ndarray):\n",
        "    x = preds.astype(np.float32)\n",
        "    x_delta = x - x.mean(axis=0, keepdims=True)\n",
        "    reaction = np.sqrt((x_delta ** 2).mean(axis=1))\n",
        "\n",
        "    if len(reaction) >= SMOOTH_WINDOW:\n",
        "        kernel = np.ones(SMOOTH_WINDOW, dtype=np.float32) / SMOOTH_WINDOW\n",
        "        reaction = np.convolve(reaction, kernel, mode=\"same\")\n",
        "\n",
        "    return x_delta, reaction\n",
        "\n",
        "def _metrics(values: np.ndarray):\n",
        "    return {\n",
        "        \"peak\": float(np.max(values)) if len(values) else float(\"nan\"),\n",
        "        \"mean\": float(np.mean(values)) if len(values) else float(\"nan\"),\n",
        "        \"auc\": float(np.sum(values)) if len(values) else float(\"nan\"),\n",
        "    }\n",
        "\n",
        "def _plot_reaction(reaction, title, fname, color=\"#DC2626\"):\n",
        "    fig = plt.figure(figsize=(10, 2.8))\n",
        "    plt.plot(reaction, marker=\"o\", lw=1.6, color=color)\n",
        "    plt.title(title)\n",
        "    plt.xlabel(\"Timestep (s)\")\n",
        "    plt.ylabel(\"RMS delta\")\n",
        "    plt.grid(True, alpha=0.2)\n",
        "    _savefig(fig, fname)\n",
        "    plt.show()\n",
        "    plt.close(fig)\n",
        "\n",
        "def _plot_metrics_bar(metrics, title, fname):\n",
        "    fig = plt.figure(figsize=(6.5, 3.2))\n",
        "    keys = [\"peak\", \"mean\", \"auc\"]\n",
        "    vals = [metrics[k] for k in keys]\n",
        "    plt.bar(keys, vals, color=[\"#111827\", \"#2563EB\", \"#DC2626\"])\n",
        "    plt.title(title)\n",
        "    plt.ylabel(\"Value\")\n",
        "    plt.grid(True, axis=\"y\", alpha=0.2)\n",
        "    _savefig(fig, fname)\n",
        "    plt.show()\n",
        "    plt.close(fig)\n",
        "\n",
        "# ----- Prepare user audio safely -----\n",
        "clip_user_source = _ensure_wav(Path(audio_path))\n",
        "y_user, sr_user = _load_audio_mono(clip_user_source)\n",
        "y_user = _trim_audio(y_user, sr_user, MAX_SECONDS)\n",
        "\n",
        "clip_user_path = Path(\"./cache\") / \"clip_user_trim.wav\"\n",
        "sf.write(str(clip_user_path), y_user, sr_user)\n",
        "\n",
        "clip_silence_path = Path(\"./cache\") / \"clip_silence.wav\"\n",
        "sf.write(str(clip_silence_path), np.zeros_like(y_user, dtype=np.float32), sr_user)\n",
        "\n",
        "clip_baseline_path = Path(\"./cache\") / \"clip_baseline_noise.wav\"\n",
        "rng = np.random.default_rng(0)\n",
        "noise = rng.standard_normal(len(y_user)).astype(np.float32)\n",
        "noise_fft = np.fft.rfft(noise)\n",
        "freqs = np.fft.rfftfreq(len(noise), d=1.0 / sr_user)\n",
        "shape = 1.0 / np.sqrt(np.maximum(freqs, 1e-6))\n",
        "noise_fft *= shape\n",
        "pink_noise = np.fft.irfft(noise_fft).astype(np.float32)\n",
        "pink_noise = 0.15 * (pink_noise / (np.max(np.abs(pink_noise)) + 1e-6))\n",
        "sf.write(str(clip_baseline_path), pink_noise, sr_user)\n",
        "\n",
        "clips = [\n",
        "    (\"clip_user\", clip_user_path),\n",
        "    (\"clip_silence\", clip_silence_path),\n",
        "    (\"clip_baseline\", clip_baseline_path),\n",
        "]\n",
        "\n",
        "demo_results = {}\n",
        "\n",
        "for clip_name, path in clips:\n",
        "    print(\"\\n===\", clip_name, \"===\")\n",
        "\n",
        "    y, sr = _load_audio_mono(path)\n",
        "\n",
        "    _plot_waveform(y, sr, f\"{clip_name}: Waveform\", f\"{clip_name}_01_waveform.png\")\n",
        "    _plot_spectrogram(y, sr, f\"{clip_name}: Log Spectrogram\", f\"{clip_name}_02_spectrogram.png\")\n",
        "    _plot_rms(y, sr, f\"{clip_name}: Loudness (RMS) Over Time\", f\"{clip_name}_03_rms.png\")\n",
        "\n",
        "    df_audio = _safe_audio_df(model, path)\n",
        "    preds, segments = model.predict(events=df_audio)\n",
        "    x_delta, reaction = _reaction_from_preds(preds)\n",
        "    raw_metrics = _metrics(reaction)\n",
        "\n",
        "    _plot_reaction(reaction, f\"{clip_name}: Raw TRIBE Reaction\", f\"{clip_name}_04_reaction_raw.png\")\n",
        "    _plot_metrics_bar(raw_metrics, f\"{clip_name}: Raw Reaction Summary\", f\"{clip_name}_05_metrics_raw.png\")\n",
        "\n",
        "    demo_results[clip_name] = {\n",
        "        \"path\": str(path),\n",
        "        \"duration_s\": float(len(y) / sr),\n",
        "        \"timesteps_kept\": int(preds.shape[0]),\n",
        "        \"reaction_raw\": reaction,\n",
        "        \"metrics_raw\": raw_metrics,\n",
        "    }\n",
        "\n",
        "    if clip_name in {\"clip_user\", \"clip_silence\"}:\n",
        "        demo_results[clip_name][\"preds\"] = preds\n",
        "        demo_results[clip_name][\"segments\"] = segments\n",
        "        demo_results[clip_name][\"x_delta\"] = x_delta\n",
        "\n",
        "    del y, df_audio\n",
        "    if clip_name == \"clip_baseline\":\n",
        "        del preds, segments, x_delta\n",
        "    gc.collect()\n",
        "\n",
        "    try:\n",
        "        import torch\n",
        "        if torch.cuda.is_available():\n",
        "            torch.cuda.empty_cache()\n",
        "    except Exception:\n",
        "        pass\n",
        "\n",
        "# ----- Convert to \"above silence\" metrics for investor-facing comparison -----\n",
        "silence_reaction = demo_results[\"clip_silence\"][\"reaction_raw\"]\n",
        "\n",
        "for clip_name in [\"clip_user\", \"clip_baseline\"]:\n",
        "    reaction = demo_results[clip_name][\"reaction_raw\"]\n",
        "    n = min(len(reaction), len(silence_reaction))\n",
        "    excess = np.maximum(0, reaction[:n] - silence_reaction[:n])\n",
        "    demo_results[clip_name][\"reaction_excess\"] = excess\n",
        "    demo_results[clip_name][\"metrics_excess\"] = _metrics(excess)\n",
        "\n",
        "demo_results[\"clip_silence\"][\"reaction_excess\"] = np.zeros_like(silence_reaction)\n",
        "demo_results[\"clip_silence\"][\"metrics_excess\"] = _metrics(demo_results[\"clip_silence\"][\"reaction_excess\"])\n",
        "\n",
        "# ----- Overlay comparison: above-silence only -----\n",
        "fig = plt.figure(figsize=(10, 3.2))\n",
        "colors = {\n",
        "    \"clip_user\": \"#DC2626\",\n",
        "    \"clip_silence\": \"#111827\",\n",
        "    \"clip_baseline\": \"#2563EB\",\n",
        "}\n",
        "for name in [\"clip_user\", \"clip_silence\", \"clip_baseline\"]:\n",
        "    plt.plot(\n",
        "        demo_results[name][\"reaction_excess\"],\n",
        "        marker=\"o\",\n",
        "        lw=1.6,\n",
        "        label=name,\n",
        "        color=colors[name],\n",
        "    )\n",
        "plt.title(\"TRIBE Reaction Above Silence\")\n",
        "plt.xlabel(\"Timestep (s)\")\n",
        "plt.ylabel(\"Excess RMS delta\")\n",
        "plt.grid(True, alpha=0.2)\n",
        "plt.legend()\n",
        "_savefig(fig, \"compare_06_reaction_above_silence.png\")\n",
        "plt.show()\n",
        "plt.close(fig)\n",
        "\n",
        "# ----- Summary table: above-silence metrics -----\n",
        "rows = []\n",
        "for name in [\"clip_user\", \"clip_silence\", \"clip_baseline\"]:\n",
        "    m = demo_results[name][\"metrics_excess\"]\n",
        "    rows.append([\n",
        "        name,\n",
        "        f'{demo_results[name][\"duration_s\"]:.2f}',\n",
        "        str(demo_results[name][\"timesteps_kept\"]),\n",
        "        f'{m[\"peak\"]:.4f}',\n",
        "        f'{m[\"mean\"]:.4f}',\n",
        "        f'{m[\"auc\"]:.4f}',\n",
        "    ])\n",
        "\n",
        "rows_sorted = sorted(rows, key=lambda x: float(x[3]), reverse=True)\n",
        "\n",
        "fig = plt.figure(figsize=(10, 2.6))\n",
        "plt.axis(\"off\")\n",
        "table = plt.table(\n",
        "    cellText=rows_sorted,\n",
        "    colLabels=[\"clip\", \"duration(s)\", \"timesteps\", \"peak_above_sil\", \"mean_above_sil\", \"auc_above_sil\"],\n",
        "    loc=\"center\",\n",
        "    cellLoc=\"center\",\n",
        ")\n",
        "table.auto_set_font_size(False)\n",
        "table.set_fontsize(10.5)\n",
        "table.scale(1, 1.4)\n",
        "plt.title(\"TRIBE Summary Relative to Silence\", pad=14)\n",
        "_savefig(fig, \"compare_07_summary_relative_to_silence.png\")\n",
        "plt.show()\n",
        "plt.close(fig)\n",
        "\n",
        "gc.collect()\n",
        "print(\"\\nArtifacts in:\", FIG_DIR)\n"
      ],
